rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que qualquer utilizador autenticado pelo Google 
    // tente ler o seu próprio documento na coleção allowed_users
    match /allowed_users/{email} {
      allow read: if request.auth != null;
    }
    
    // Permite acesso à coleção de compras e home_ambientes para usuários autenticados
    match /compras/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /home_ambientes/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /notas/{document=**} {
      allow read, write: if request.auth != null;
    }

    // === FINANCEIRO (removível) — apagar este bloco inteiro para remover o módulo ===
    match /financeiro_config/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /financeiro_entrada/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /financeiro_evolucao/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /financeiro_incc/{document=**} {
      allow read, write: if request.auth != null;
    }
    // === FIM FINANCEIRO ===

    // Regra padrão: bloqueia tudo o resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
