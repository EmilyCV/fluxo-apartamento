rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que qualquer utilizador autenticado pelo Google 
    // tente ler o seu próprio documento na coleção allowed_users
    match /allowed_users/{email} {
      allow read: if request.auth != null;
    }
    
    // Regra padrão: bloqueia tudo o resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}